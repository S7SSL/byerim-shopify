{%- comment -%}
  ByErim — Google Ads Enhanced Conversions
  Fires on the order confirmation (thank you) page only.
  Passes hashed customer data to improve conversion match rates.

  Deployment:
    Option A (recommended): Include this snippet in layout/theme.liquid
    Option B (quick): Paste the contents into Shopify Admin → Settings →
                      Checkout → Order status page (Additional scripts)

  Required: Replace CONVERSION_LABEL_HERE with the actual label from
            Google Ads → Conversions → [Purchase conversion] → Tag setup
{%- endcomment -%}

{% if first_time_accessed %}
{% if checkout %}

<script>
  // ── Google Ads Enhanced Conversions ───────────────────────────────────
  // Pass user-provided data for improved match accuracy
  gtag('set', 'user_data', {
    {% if customer.email != blank %}
    "email": {{ customer.email | downcase | json }},
    {% endif %}
    {% if checkout.billing_address.phone != blank %}
    "phone_number": {{ checkout.billing_address.phone | json }},
    {% endif %}
    "address": {
      {% if checkout.billing_address.first_name != blank %}
      "first_name": {{ checkout.billing_address.first_name | downcase | json }},
      {% endif %}
      {% if checkout.billing_address.last_name != blank %}
      "last_name": {{ checkout.billing_address.last_name | downcase | json }},
      {% endif %}
      {% if checkout.billing_address.address1 != blank %}
      "street": {{ checkout.billing_address.address1 | downcase | json }},
      {% endif %}
      {% if checkout.billing_address.city != blank %}
      "city": {{ checkout.billing_address.city | downcase | json }},
      {% endif %}
      {% if checkout.billing_address.zip != blank %}
      "postal_code": {{ checkout.billing_address.zip | downcase | json }},
      {% endif %}
      {% if checkout.billing_address.country_code != blank %}
      "country": {{ checkout.billing_address.country_code | downcase | json }}
      {% endif %}
    }
  });

  // ── Purchase Conversion Event ──────────────────────────────────────────
  gtag('event', 'purchase', {
    'send_to': 'AW-10862797813/CONVERSION_LABEL_HERE',
    'value': {{ checkout.total_price | divided_by: 100.0 }},
    'currency': {{ shop.currency | json }},
    'transaction_id': {{ order_number | json }},
    'new_customer': {% if customer.orders_count <= 1 %}true{% else %}false{% endif %}
  });
  // ──────────────────────────────────────────────────────────────────────
</script>

{% endif %}
{% endif %}
